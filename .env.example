# AI Log Analyzer — ortam değişkenleri örneği.
# Bu dosyayı `.env` olarak kopyalayıp kendi değerlerinizi yazın. `.env` git'e girmez (bkz. .gitignore).

# --- Veritabanı (docker-compose.yml ile uyumlu varsayılanlar) ---
DB_URL=jdbc:postgresql://localhost:5432/loganalyzer
DB_USERNAME=loganalyzer
DB_PASSWORD=loganalyzer

# --- Yapay Zeka (Gün 4'te devreye girecek) ---
# Google AI Studio'dan alınan ücretsiz Gemini API anahtarı: https://aistudio.google.com/apikey
GEMINI_API_KEY=buraya-api-anahtarini-yaz
# OpenAI yedek sağlayıcı (opsiyonel)
OPENAI_API_KEY=

# Aktif profil: 'mock' → AI çağrısı yapmadan sahte yanıt döner (anahtar gerekmez, demo/geliştirme için)
SPRING_PROFILES_ACTIVE=default
